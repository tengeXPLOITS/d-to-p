-- Dragging logic (drag window by titleBar)
local dragging = false
local dragStart = Vector2.new()
local startPos = window.Position

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = window.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        local abs = {x = (startPos.X.Offset + delta.X), y = (startPos.Y.Offset + delta.Y)}
        window.Position = UDim2.new(startPos.X.Scale, abs.x, startPos.Y.Scale, abs.y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- Make UI scale-friendly on resize
local function onResize()
    local screenSize = workspace.CurrentCamera.ViewportSize
    if screenSize.X < 700 then
        window.Size = UDim2.new(0.9, 0, 0.8, 0)
    else
        window.Size = UDim2.new(0.35, 0, 0.55, 0)
    end
end
RunService.Heartbeat:Connect(onResize)
onResize()

