-- Server hop core functions
local function pickRandomCandidates(list, maxCount)
    local out = {}
    local n = math.min(#list, maxCount)
    for i=1,n do
        local idx = math.random(1, #list)
        table.insert(out, list[idx])
        table.remove(list, idx)
    end
    return out
end

function serverHopNow(immediate)
    local placeId = tostring(HOP_PLACE_ID or game.PlaceId)
    local servers = {}
    -- Loop until we successfully teleport
    while true do
        local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&limit=100"
        local bodyStr = nil
        local ok, res = pcall(function()
            if httprequest then
                local r = httprequest({Url = url, Method = "GET"})
                return r and r.Body
            else
                return HttpService:GetAsync(url)
            end
        end)

        if ok and res then
            bodyStr = res
        else
            warn("Failed to fetch server list; retrying shortly")
            task.wait(1)
        end

        if bodyStr then
            local body = nil
            pcall(function() body = HttpService:JSONDecode(bodyStr) end)
            if body and body.data then
                local preferred = {}
                local available = {}
                local other = {}
                for _, v in ipairs(body.data) do
                    if type(v) == "table" and v.id then
                        local playing = tonumber(v.playing)
                        local maxP = tonumber(v.maxPlayers)
                        local prefTarget = tonumber(SETTINGS.serverPreferredPlayers) or 0
                        if prefTarget > 0 and playing and playing == prefTarget then
                            table.insert(preferred, v.id)
                        elseif prefTarget <= 0 and playing and playing >= 21 and playing <= 22 then
                            table.insert(preferred, v.id)
                        elseif playing and maxP and playing < maxP then
                            table.insert(available, v.id)
                        else
                            table.insert(other, v.id)
                        end
                    end
                end
                if tonumber(SETTINGS.serverPreferredPlayers or 0) > 0 then
                    if #preferred > 0 then
                        servers = preferred
                    else
                        -- no exact matches: pick the server with the highest player count (prefer not-full servers)
                        local bestId = nil
                        local bestPlaying = -1
                        for _, sv in ipairs(body.data) do
                            if type(sv) == "table" and sv.id then
                                local playing = tonumber(sv.playing) or 0
                                local maxP = tonumber(sv.maxPlayers) or 0
                                local notFull = (maxP > 0) and (playing < maxP) or true
                                if notFull and playing > bestPlaying then
                                    bestPlaying = playing
                                    bestId = sv.id
                                end
                            end
                        end
                        if not bestId then
                            -- if no not-full server found, pick absolute max
                            for _, sv in ipairs(body.data) do
                                if type(sv) == "table" and sv.id then
                                    local playing = tonumber(sv.playing) or 0
                                    if playing > bestPlaying then
                                        bestPlaying = playing
                                        bestId = sv.id
                                    end
                                end
                            end
                        end
                        if bestId then
                            servers = {bestId}
                        elseif #available > 0 then
                            servers = available
                        else
                            servers = other
                        end
                    end
                else
                    if #preferred > 0 then
                        servers = preferred
                    elseif #available > 0 then
                        servers = available
                    else
                        servers = other
                    end
                end
            end
        end

        if #servers == 0 then
            updateServerMonitor(0)
            task.wait(1)
        else
            updateServerMonitor(#servers)
            local instanceId = servers[math.random(1, #servers)]
            local ok2 = pcall(function()
                -- queue the UI to load on teleport (if executor supports it)
                pcall(queueLoadOnTeleport)
                -- make non-blocking attempt and allow retry
                TeleportService:TeleportToPlaceInstance(tonumber(placeId) or placeId, instanceId, LocalPlayer)
            end)
            if ok2 then
                return
            else
                warn("Teleport attempt failed, retrying...")
                task.wait(1)
            end
        end
    end
end

