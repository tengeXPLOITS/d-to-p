local function IsInOkfeanCommunity()
    if game.CreatorType == Enum.CreatorType.Group and game.CreatorId == COMMUNITY_ID then
        return true
    end

    local success, response = pcall(function()
        local data = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/multiget-place-details?placeIds=" .. game.PlaceId))
        if data and data[1] and data[1].universeId then
            return game.CreatorId == COMMUNITY_ID
        end
        return false
    end)

    return success and response == true
end

