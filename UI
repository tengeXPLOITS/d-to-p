local function getCommunityPlaceIds()
    local placeIds = {}
    local seen = {}
    local function addId(id)
        local n = tonumber(id)
        if n and n > 0 and not seen[n] then
            seen[n] = true
            table.insert(placeIds, n)
        end
    end

    addId(HOP_PLACE_ID)
    addId(game.PlaceId)

    local ok, res = pcall(function()
        local url = "https://games.roblox.com/v1/groups/36062881/games?accessFilter=Public&limit=100"
        if httprequest then
            local r = httprequest({Url = url, Method = "GET", Headers = { ["User-Agent"] = "Roblox" }})
            return r and (r.Body or r.body or r.responseBody or r.text)
        else
            return HttpService:GetAsync(url)
        end
    end)

    if ok and res then
        pcall(function()
            local body = HttpService:JSONDecode(res)
            if body and body.data then
                for _, place in ipairs(body.data) do
                    if type(place) == "table" then
                        addId(place.id or place.placeId or place.place_id)
                    end
                end
            end
        end)
    end

    return placeIds
end

