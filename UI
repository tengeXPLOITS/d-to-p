local function isPositionInPlazaArea(pos)
    if typeof(pos) ~= "Vector3" then
        return false
    end

    return pos.X >= PLAZA_AREA_MIN.X
        and pos.X <= PLAZA_AREA_MAX.X
        and pos.Y >= PLAZA_AREA_MIN.Y
        and pos.Y <= PLAZA_AREA_MAX.Y
        and pos.Z >= PLAZA_AREA_MIN.Z
        and pos.Z <= PLAZA_AREA_MAX.Z
end

local function getActivePlayers(maxDistance)
    local active = {}
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then
        return active
    end

    local limit = math.max(1, tonumber(maxDistance) or 40)
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local playerHRP = player.Character:FindFirstChild("HumanoidRootPart")
            if playerHRP then
                local playerPos = playerHRP.Position
                local dist = (playerPos - hrp.Position).Magnitude
                if isPositionInPlazaArea(playerPos) and dist <= limit then
                    table.insert(active, {
                        player = player,
                        position = playerPos,
                        distance = dist,
                    })
                end
            end
        end
    end

    table.sort(active, function(a, b)
        return a.distance < b.distance
    end)

    return active
end

local function getCrowdCenter(activePlayers)
    if #activePlayers == 0 then
        return nil
    end

    local total = Vector3.new(0, 0, 0)
    for _, entry in ipairs(activePlayers) do
        total += entry.position
    end

    return total / #activePlayers
end

local function startBoothPatrol()
    if boothPatrolRunning then
        return
    end

    boothPatrolRunning = true
    boothPatrolThread = task.spawn(function()
        local patrolIndex = 0
        local crowdTriggered = false
        local crowdTriggerAt = 0
        local crowdFollowUntil = 0
        local lookCooldown = 0
        local jumpCooldown = 0
        local cheerCooldown = 0
        local lastLookedPlayer = nil
        local crowdApproachTarget = nil
        local lastMoveAt = os.clock()

        while SETTINGS.autoWalkAndInteract do
            local now = os.clock()
            local activePlayers = getActivePlayers(40)
            local crowdCount = #activePlayers
            local nearestPlayer = crowdCount > 0 and activePlayers[1].player or nil
            local booth = getOwnedBoothModel()

            if crowdCount >= 4 then
                if not crowdTriggered then
                    crowdTriggered = true
                    crowdTriggerAt = now
                    crowdFollowUntil = now + 80
                    lookCooldown = now + 1
                    jumpCooldown = now + 6
                    cheerCooldown = now + 15
                    crowdApproachTarget = getCrowdCenter(activePlayers)
                    performCrowdEmote("wave")
                end

                if now < crowdFollowUntil then
                    local crowdTarget = crowdApproachTarget or getCrowdCenter(activePlayers)
                    if crowdTarget then
                        moveCharacterToWaypoint(crowdTarget, 24)
                        lastMoveAt = now
                    end

                    if nearestPlayer and nearestPlayer ~= lastLookedPlayer and now >= lookCooldown then
                        quickLookAtPlayer(nearestPlayer)
                        lastLookedPlayer = nearestPlayer
                        lookCooldown = now + math.random(12, 20)
                    end

                    if now >= jumpCooldown then
                        burstJumpAroundCrowd()
                        jumpCooldown = now + math.random(6, 10)
                    end

                    if now >= cheerCooldown then
                        performCrowdEmote("cheer")
                        cheerCooldown = now + math.random(25, 40)
                    end
                else
                    if booth then
                        local returnTarget = getBoothReturnTarget(booth)
                        if returnTarget then
                            moveCharacterToWaypoint(returnTarget, 24)
                            faceAwayFromBooth(booth)
                            lastMoveAt = now
                        end
                    end
                    crowdTriggered = false
                    crowdFollowUntil = 0
                    crowdApproachTarget = nil
                    lastLookedPlayer = nil
                    cheerCooldown = 0
                end
            else
                crowdTriggered = false
                crowdFollowUntil = 0
                crowdApproachTarget = nil
                lastLookedPlayer = nil
                cheerCooldown = 0

                if nearestPlayer and nearestPlayer ~= lastLookedPlayer and math.random() < 0.2 and now >= lookCooldown then
                    quickLookAtPlayer(nearestPlayer)
                    lastLookedPlayer = nearestPlayer
                    lookCooldown = now + math.random(12, 20)
                end

                if now - lastMoveAt >= 20 then
                    if booth then
                        local returnTarget = getBoothReturnTarget(booth)
                        if returnTarget then
                            moveCharacterToWaypoint(returnTarget, 24)
                            faceAwayFromBooth(booth)
                            lastMoveAt = now
                        end
                    end
                else
                    local patrolTargets = booth and getBoothPatrolTargets(booth) or {}
                    if #patrolTargets > 0 then
                        patrolIndex = patrolIndex % #patrolTargets + 1
                        moveCharacterToWaypoint(patrolTargets[patrolIndex], 21)
                        lastMoveAt = now
                    end
                end
            end

            task.wait(1.0)
        end

        boothPatrolRunning = false
        boothPatrolThread = nil
    end)
end

local function cancelBoothPatrolStart()
    if boothPatrolStartThread then
        pcall(function()
            task.cancel(boothPatrolStartThread)
        end)
        boothPatrolStartThread = nil
    end
end

local function scheduleBoothPatrolStart(delaySeconds)
    cancelBoothPatrolStart()
    boothPatrolStartThread = task.spawn(function()
        task.wait(math.max(0, tonumber(delaySeconds) or 20))
        if SETTINGS.autoWalkAndInteract then
            startBoothPatrol()
        end
        boothPatrolStartThread = nil
    end)
end

local function stopBoothPatrol()
    if boothPatrolThread then
        pcall(function()
            task.cancel(boothPatrolThread)
        end)
        boothPatrolThread = nil
    end
    boothPatrolRunning = false
end

