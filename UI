local function refreshServerBrowser()
    local gui = ensureServerBrowser()
    gui.Enabled = true
    gui.Parent = PlayerGui

    if not serverBrowserList then
        return
    end

    for _, child in ipairs(serverBrowserList:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end

    local placeId = tostring(HOP_PLACE_ID or game.PlaceId)
    local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&limit=100"
    local ok, res = pcall(function()
        if httprequest then
            local r = httprequest({Url = url, Method = "GET"})
            return r and r.Body
        else
            return HttpService:GetAsync(url)
        end
    end)

    if not (ok and res) then
        local empty = new(serverBrowserList, "Frame", {Size = UDim2.new(1, 0, 0, 28), BackgroundTransparency = 1})
        local label = new(empty, "TextLabel", {Text = "Unable to load server list.", BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(220, 220, 220), Font = Enum.Font.Gotham, TextSize = 13, Size = UDim2.new(1, 0, 1, 0), TextXAlignment = Enum.TextXAlignment.Left})
        return
    end

    local body = nil
    pcall(function() body = HttpService:JSONDecode(res) end)
    if not (body and body.data) then
        local empty = new(serverBrowserList, "Frame", {Size = UDim2.new(1, 0, 0, 28), BackgroundTransparency = 1})
        local label = new(empty, "TextLabel", {Text = "No server data returned.", BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(220, 220, 220), Font = Enum.Font.Gotham, TextSize = 13, Size = UDim2.new(1, 0, 1, 0), TextXAlignment = Enum.TextXAlignment.Left})
        return
    end

    local rows = {}
    for _, v in ipairs(body.data) do
        if type(v) == "table" and v.id then
            local playing = tonumber(v.playing) or 0
            local maxP = tonumber(v.maxPlayers) or 0
            local row = new(serverBrowserList, "Frame", {Size = UDim2.new(1, 0, 0, 36), BackgroundColor3 = Color3.fromRGB(28, 28, 28), BorderSizePixel = 0})
            local label = new(row, "TextLabel", {Text = "Players " .. tostring(playing) .. "/" .. tostring(maxP) .. "  •  Server " .. tostring(v.id:sub(1, 8)), BackgroundTransparency = 1, TextColor3 = Color3.new(1, 1, 1), Font = Enum.Font.Gotham, TextSize = 13, Size = UDim2.new(1, -12, 1, 0), Position = UDim2.new(0, 6, 0, 0), TextXAlignment = Enum.TextXAlignment.Left})
            table.insert(rows, row)
        end
    end

    if #rows == 0 then
        local empty = new(serverBrowserList, "Frame", {Size = UDim2.new(1, 0, 0, 28), BackgroundTransparency = 1})
        local label = new(empty, "TextLabel", {Text = "No public servers were returned.", BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(220, 220, 220), Font = Enum.Font.Gotham, TextSize = 13, Size = UDim2.new(1, 0, 1, 0), TextXAlignment = Enum.TextXAlignment.Left})
    end
end

