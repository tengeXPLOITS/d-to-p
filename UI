local function parseNumberValue(value)
    if value == nil then return nil end
    local str = tostring(value)
    str = string.gsub(str, "%s", "")
    str = string.gsub(str, "[^%d%.%-]", "")
    return tonumber(str)
end

local function ensureRaisedStat()
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if not leaderstats then
        leaderstats = Instance.new("Folder")
        leaderstats.Name = "leaderstats"
        leaderstats.Parent = LocalPlayer
    end
    local raised = leaderstats:FindFirstChild("Raised")
    if not raised then
        raised = Instance.new("IntValue")
        raised.Name = "Raised"
        raised.Parent = leaderstats
    end
    return raised
end

local function findRaisedStat()
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if leaderstats then
        local raised = leaderstats:FindFirstChild("Raised") or leaderstats:FindFirstChild("raised")
        if raised and (raised:IsA("IntValue") or raised:IsA("NumberValue") or raised:IsA("StringValue")) then
            return raised
        end
    end

    local function findStat(root)
        for _, child in ipairs(root:GetChildren()) do
            if (child.Name:lower() == "raised") and (child:IsA("IntValue") or child:IsA("NumberValue") or child:IsA("StringValue")) then
                return child
            end
        end
        for _, child in ipairs(root:GetChildren()) do
            local found = findStat(child)
            if found then return found end
        end
        return nil
    end
    return findStat(LocalPlayer)
end

local function findPendingValue()
    local pendingRoot
    for _, desc in ipairs(LocalPlayer:GetDescendants()) do
        if desc.Name == "PedingRobux" then
            pendingRoot = desc
            break
        end
    end
    if not pendingRoot then
        return nil
    end
    local pendingText
    local listObj = pendingRoot:FindFirstChild("PedingRobuxList") or pendingRoot:FindFirstChild("Pending")
    if listObj then
        pendingText = listObj.Text or listObj.Value
    else
        for _, desc in ipairs(pendingRoot:GetDescendants()) do
            if desc.Name == "PedingRobuxList" or desc.Name == "Pending" then
                pendingText = desc.Text or desc.Value
                break
            end
        end
    end
    return parseNumberValue(pendingText)
end

local function getCurrentRaisedValue()
