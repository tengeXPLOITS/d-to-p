-- Queue-on-teleport helper for provided UI loadstring
local function queueLoadOnTeleport()
    if GLOBAL_ENV.DonateToPlayers_QueuedTeleport then
        return
    end

    local settingsJson = "{}"
    pcall(function()
        settingsJson = HttpService:JSONEncode(SETTINGS or {})
    end)

    local code = string.format([[
        repeat task.wait() until game:IsLoaded()
        -- restore settings file so newly loaded UI picks up user preferences
        pcall(function()
            if writefile then
                pcall(function()
                    writefile(%q, %q)
                end)
            end
        end)

        local ok, err = pcall(function()
            local Players = game:GetService("Players")
            local LocalPlayer = Players.LocalPlayer
            local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
            local UI_NAME = "DonateToPlayersUI"
            if PlayerGui:FindFirstChild(UI_NAME) then
                return
            end
            loadstring(game:HttpGet(%q))()
        end)
        if not ok then
            warn(err)
        end
    ]], SETTINGS_FILE, settingsJson, UI_SOURCE_URL)

    local q = queue_on_teleport or (syn and syn.queue_on_teleport) or (queue_on_teleport) or (fluxus and fluxus.queue_on_teleport)
    if q then
        pcall(q, code)
        GLOBAL_ENV.DonateToPlayers_QueuedTeleport = true
        warn("Queued UI loadstring on teleport and included settings")
    else
        warn("queue_on_teleport not available in this executor")
    end
end

