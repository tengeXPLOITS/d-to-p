            end
            loadstring(game:HttpGet(%q))()
        end)
        if not ok then
            warn(err)
        end
    ]], SETTINGS_FILE, settingsJson, UI_SOURCE_URL)

    local q = queue_on_teleport or (syn and syn.queue_on_teleport) or (queue_on_teleport) or (fluxus and fluxus.queue_on_teleport)
    if q then
        pcall(q, code)
        GLOBAL_ENV.DonateToPlayers_QueuedTeleport = true
        warn("Queued UI loadstring on teleport and included settings")
    else
        warn("queue_on_teleport not available in this executor")
    end
end

