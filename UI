    local toggled = initial
    box.MouseButton1Click:Connect(function()
        toggled = not toggled
        box.Text = toggled and "✓" or ""
        pcall(callback, toggled)
    end)
    local obj = {}
    function obj:Set(b)
        toggled = b and true or false
        box.Text = toggled and "✓" or ""
        pcall(callback, toggled)
    end
    return obj, container
