    end
    return HOP_PLACE_ID or game.PlaceId
end

local function shouldUseAntiNonBusyServers()
    local currentPlayers = tonumber(Players.NumPlayers) or 0
    return SETTINGS.antiNonBusyServers and currentPlayers < SERVER_HOP_MIN_PLAYERS
end

local function fetchServerList(placeId)
    local url = "https://games.roblox.com/v1/games/" .. tostring(placeId) .. "/servers/Public?sortOrder=Desc&limit=100"
    local ok, res = pcall(function()
        if httprequest then
            local r = httprequest({Url = url, Method = "GET", Headers = { ["User-Agent"] = "Roblox" }})
            return r and (r.Body or r.body or r.responseBody or r.text)
        elseif type(HttpService.GetAsync) == "function" then
            return HttpService:GetAsync(url)
        else
            return game:HttpGet(url)
        end
    end)

    if ok and res then
        return res
    end
    return nil, res or "server list request failed"
end

local function tryTeleportToServer(placeId, instanceId)
    local success, err = pcall(function()
        pcall(queueLoadOnTeleport)
        if instanceId and instanceId ~= "" then
            TeleportService:TeleportToPlaceInstance(tonumber(placeId) or placeId, tostring(instanceId), LocalPlayer)
        else
            TeleportService:Teleport(tonumber(placeId) or placeId, LocalPlayer)
        end
    end)

    if success then
        return true
    end

    local fallbackOk, fallbackErr = pcall(function()
        TeleportService:Teleport(tonumber(placeId) or placeId, LocalPlayer)
    end)
    if fallbackOk then
        return true
    end

    return false, fallbackErr or err
end

function serverHopNow(immediate)
    local placeIds = getHopPlaceIds()
    local attempt = 0
    local lastError = nil

    while true do
        attempt = attempt + 1
        showNotification("Server hop started")

        local success = false
        for _, placeId in ipairs(placeIds) do
            local servers = {}
            local body = nil
            local bodyStr = nil
            local availableServerCount = 0

            for fetchTry = 1, 3 do
                bodyStr, lastError = fetchServerList(placeId)
                if bodyStr then
                    pcall(function() body = HttpService:JSONDecode(bodyStr) end)
                    if body and body.data then
                        local preferred = {}
                        local busy = {}
                        local available = {}
                        local other = {}
                        local highPop = {}
                        local minPlayers = shouldUseAntiNonBusyServers() and SERVER_HOP_MIN_PLAYERS or 0
                        local prefRange = parsePreferredPlayerTarget(SETTINGS.serverPreferredPlayers)
                        for _, v in ipairs(body.data) do
                            if type(v) == "table" and v.id then
                                local playing = tonumber(v.playing) or 0
                                local maxP = tonumber(v.maxPlayers) or 0
                                local notFull = (maxP > 0) and (playing < maxP) or true
                                if prefRange.max > 0 and notFull and prefersServer(playing, prefRange) then
                                    table.insert(preferred, { id = v.id, playing = playing, maxPlayers = maxP })
                                elseif minPlayers > 0 and playing >= minPlayers and notFull then
                                    table.insert(busy, v.id)
                                elseif playing and maxP and playing >= SERVER_HOP_FALLBACK_MIN_PLAYERS and playing <= SERVER_HOP_FALLBACK_MAX_PLAYERS and playing < maxP then
                                    table.insert(highPop, v.id)
                                elseif playing and maxP and playing < maxP then
                                    table.insert(available, v.id)
                                elseif notFull then
                                    table.insert(other, v.id)
                                end
                                if notFull then
                                    availableServerCount = availableServerCount + 1
                                end
                            end
                        end

                        if prefRange.max > 0 and #preferred > 0 then
                            preferred = sortCandidatesByPreferred(preferred, prefRange)
                            servers = { preferred[1].id }
                        elseif minPlayers > 0 then
                            servers = busy
                            if #servers == 0 then
                                servers = highPop
                            end
                            if #servers == 0 then
                                servers = available
                            end
                            if #servers == 0 then
                                servers = other
                            end
                        elseif #available > 0 then
                            servers = available
                        else
                            servers = other
                        end

                        if prefRange.max > 0 and #servers == 0 then
                            if #highPop > 0 then
                                servers = { highPop[1] }
                            elseif #available > 0 then
                                servers = { available[1] }
                            elseif #other > 0 then
                                servers = { other[1] }
                            end
                        end

                        if #servers > 1 then
                            servers = pickRandomCandidates(servers, 1)
                        end

                        break
                    end
                end

                task.wait(0.5)
            end

            if #servers == 0 then
                -- no matching server found
            else
                local instanceId = servers[math.random(1, #servers)]
                local ok, err = tryTeleportToServer(placeId, instanceId)
                if ok then
                    showNotification("Teleporting to another server")
                    return true
                end

                lastError = err or lastError or "Teleport failed"
                success = false
            end
        end

        if attempt >= 6 then
            showNotification("Server hop failed: " .. tostring(lastError or "No available servers found"))
            return false
        end

        showNotification("Hop attempt failed; retrying")
        task.wait(2)
    end
end

-- Auto-hop loop (checks SETTINGS.autoServerHop)
local autoHopVersion = 0

local function enforceSuitableServerIfNeeded()
    if not SETTINGS.antiNonBusyServers then
        return
    end

    local currentPlayers = tonumber(Players.NumPlayers) or 0
    if currentPlayers >= SERVER_HOP_MIN_PLAYERS then
        return
    end

    pcall(function()
        showNotification("Anti-busy server check: hopping to a fuller server")
        serverHopNow(true)
    end)
end

task.spawn(function()
    while true do
        if SETTINGS.antiNonBusyServers then
            pcall(enforceSuitableServerIfNeeded)
        end
        task.wait(3)
    end
end)

task.spawn(function()
    while true do
        if SETTINGS.autoServerHop then
            local version = autoHopVersion
            local delaySeconds = getServerStayDurationSeconds()
            local delayText = formatDurationSeconds(delaySeconds)
            showNotification("Next server hop in " .. delayText)

            local elapsed = 0
            while elapsed < delaySeconds do
                task.wait(1)
                if autoHopVersion ~= version or not SETTINGS.autoServerHop then
                    break
                end
                elapsed = elapsed + 1
            end

            if SETTINGS.autoServerHop and autoHopVersion == version then
                pcall(function() serverHopNow(false) end)
            end
        else
            task.wait(1)
        end

        task.wait(10)
    end
end)

