-- Server hop core functions
local function pickRandomCandidates(list, maxCount)
    local out = {}
    local n = math.min(#list, maxCount)
    for i=1,n do
        local idx = math.random(1, #list)
        table.insert(out, list[idx])
        table.remove(list, idx)
    end
    return out
end

local function prefersServer(playing, prefRange)
    return prefRange.max > 0 and playing >= prefRange.min and playing <= prefRange.max
end

local function preferredDistance(playing, prefRange)
    if prefRange.max <= 0 then
        return math.huge
    end
    if playing < prefRange.min then
        return prefRange.min - playing
    end
    if playing > prefRange.max then
        return playing - prefRange.max
    end
    return 0
end

local function sortCandidatesByPreferred(candidates, prefRange)
    table.sort(candidates, function(a, b)
        local aPlaying = tonumber(a.playing) or 0
        local bPlaying = tonumber(b.playing) or 0
        local aPreferred = prefersServer(aPlaying, prefRange)
        local bPreferred = prefersServer(bPlaying, prefRange)
        if aPreferred ~= bPreferred then
            return aPreferred
        end
        local aDist = preferredDistance(aPlaying, prefRange)
        local bDist = preferredDistance(bPlaying, prefRange)
        if aDist ~= bDist then
            return aDist < bDist
        end
        if aPlaying ~= bPlaying then
            return aPlaying > bPlaying
        end
        return (tonumber(a.maxPlayers) or 0) > (tonumber(b.maxPlayers) or 0)
    end)
    return candidates
end

local function sortCandidatesByPlayerCount(candidates)
    table.sort(candidates, function(a, b)
        local aPlaying = tonumber(a.playing) or 0
        local bPlaying = tonumber(b.playing) or 0
        if aPlaying ~= bPlaying then
            return aPlaying > bPlaying
        end
        return (tonumber(a.maxPlayers) or 0) > (tonumber(b.maxPlayers) or 0)
    end)
    return candidates
end

local function getCommunityPlaceIds()
    local placeIds = {}
    local seen = {}
    local function addId(id)
        local n = tonumber(id)
        if n and n > 0 and not seen[n] then
            seen[n] = true
            table.insert(placeIds, n)
        end
    end

    addId(HOP_PLACE_ID)
    addId(game.PlaceId)

    local ok, res = pcall(function()
        local url = "https://games.roblox.com/v1/groups/36062881/games?accessFilter=Public&limit=100"
        if httprequest then
            local r = httprequest({Url = url, Method = "GET", Headers = { ["User-Agent"] = "Roblox" }})
            return r and (r.Body or r.body or r.responseBody or r.text)
        else
            return HttpService:GetAsync(url)
        end
    end)

    if ok and res then
        pcall(function()
            local body = HttpService:JSONDecode(res)
            if body and body.data then
                for _, place in ipairs(body.data) do
                    if type(place) == "table" then
                        addId(place.id or place.placeId or place.place_id)
                    end
                end
            end
        end)
    end

    return placeIds
end

local function getHopPlaceIds()
    local configured = tonumber(SETTINGS.serverHopPlaceId or 0)
    local ids = {}
    local seen = {}
    local function addId(id)
        local n = tonumber(id)
        if n and n > 0 and not seen[n] then
            seen[n] = true
            table.insert(ids, n)
        end
    end

    if configured and configured > 0 then
        addId(configured)
    end
    addId(HOP_PLACE_ID)
    addId(game.PlaceId)
    return ids
end

local function isCurrentServerId(serverId)
    return tostring(serverId or "") == tostring(game.JobId or "")
end

local function getHopPlaceId()
    local ids = getHopPlaceIds()
    if ids and #ids > 0 then
        return ids[1]
    end
    return HOP_PLACE_ID or game.PlaceId
end

local function shouldUseAntiNonBusyServers()
    local currentPlayers = tonumber(Players.NumPlayers) or 0
    return SETTINGS.antiNonBusyServers and currentPlayers < SERVER_HOP_MIN_PLAYERS
end

local function fetchServerList(placeId)
    local url = "https://games.roblox.com/v1/games/" .. tostring(placeId) .. "/servers/Public?sortOrder=Desc&limit=100"
    local ok, res = pcall(function()
        if httprequest then
            local r = httprequest({Url = url, Method = "GET", Headers = { ["User-Agent"] = "Roblox" }})
            return r and (r.Body or r.body or r.responseBody or r.text)
        elseif type(HttpService.GetAsync) == "function" then
            return HttpService:GetAsync(url)
        else
            return game:HttpGet(url)
        end
    end)

    if ok and res then
        return res
    end
    return nil, res or "server list request failed"
end

local function tryTeleportToServer(placeId, instanceId)
    local success, err = pcall(function()
        pcall(queueLoadOnTeleport)
        if instanceId and instanceId ~= "" then
            TeleportService:TeleportToPlaceInstance(tonumber(placeId) or placeId, tostring(instanceId), LocalPlayer)
        else
            TeleportService:Teleport(tonumber(placeId) or placeId, LocalPlayer)
        end
    end)

    if success then
        return true
    end

    local fallbackOk, fallbackErr = pcall(function()
        TeleportService:Teleport(tonumber(placeId) or placeId, LocalPlayer)
    end)
    if fallbackOk then
        return true
    end

    return false, fallbackErr or err
end

function serverHopNow(immediate)
    local placeIds = getHopPlaceIds()
    local attempt = 0
    local lastError = nil

    while true do
        attempt = attempt + 1
        showNotification("Server hop started")

        local success = false
        for _, placeId in ipairs(placeIds) do
            local servers = {}
            local body = nil
            local bodyStr = nil
            local availableServerCount = 0

            for fetchTry = 1, 3 do
                bodyStr, lastError = fetchServerList(placeId)
                if bodyStr then
                    pcall(function() body = HttpService:JSONDecode(bodyStr) end)
                    if body and body.data then
                        local preferred = {}
                        local busy = {}
                        local available = {}
                        local other = {}
                        local highPop = {}
                        local allCandidates = {}
                        local minPlayers = shouldUseAntiNonBusyServers() and SERVER_HOP_MIN_PLAYERS or 0
                        local prefRange = parsePreferredPlayerTarget(SETTINGS.serverPreferredPlayers)
                        for _, v in ipairs(body.data) do
                            if type(v) == "table" and v.id then
                                if isCurrentServerId(v.id) then
                                    continue
                                end
                                local playing = tonumber(v.playing) or 0
                                local maxP = tonumber(v.maxPlayers) or 0
                                local notFull = (maxP > 0) and (playing < maxP) or true
                                local candidate = { id = v.id, playing = playing, maxPlayers = maxP }
                                if notFull then
                                    table.insert(allCandidates, candidate)
                                end
                                if prefRange.max > 0 and notFull and prefersServer(playing, prefRange) then
                                    table.insert(preferred, candidate)
                                elseif minPlayers > 0 and playing >= minPlayers and notFull then
                                    table.insert(busy, candidate)
                                elseif playing and maxP and playing >= SERVER_HOP_FALLBACK_MIN_PLAYERS and playing <= SERVER_HOP_FALLBACK_MAX_PLAYERS and playing < maxP then
                                    table.insert(highPop, candidate)
                                elseif playing and maxP and playing < maxP then
                                    table.insert(available, candidate)
                                elseif notFull then
                                    table.insert(other, candidate)
                                end
                                if notFull then
                                    availableServerCount = availableServerCount + 1
                                end
                            end
                        end

                        if prefRange.max > 0 and #preferred > 0 then
                            preferred = sortCandidatesByPreferred(preferred, prefRange)
                            servers = { preferred[1] }
                        elseif prefRange.max > 0 and #allCandidates > 0 then
                            allCandidates = sortCandidatesByPlayerCount(allCandidates)
                            servers = { allCandidates[1] }
                        elseif minPlayers > 0 then
                            servers = busy
                            if #servers == 0 then
                                servers = highPop
                            end
                            if #servers == 0 then
                                servers = available
                            end
                            if #servers == 0 then
                                servers = other
                            end
                            if #servers > 0 then
                                servers = sortCandidatesByPlayerCount(servers)
                            end
                        elseif #highPop > 0 then
                            servers = sortCandidatesByPlayerCount(highPop)
                        elseif #available > 0 then
                            servers = sortCandidatesByPlayerCount(available)
                        else
                            servers = sortCandidatesByPlayerCount(other)
                        end

                        if prefRange.max > 0 and #servers == 0 then
                            if #allCandidates > 0 then
                                servers = { allCandidates[1] }
                            elseif #highPop > 0 then
                                servers = { highPop[1] }
                            elseif #available > 0 then
                                servers = { available[1] }
                            elseif #other > 0 then
                                servers = { other[1] }
                            end
                        end

                        if #servers > 1 then
                            servers = pickRandomCandidates(servers, 1)
                        end

                        break
                    end
                end

                task.wait(0.5)
            end

            if #servers == 0 then
                -- no matching server found
            else
                local selectedServer = servers[math.random(1, #servers)]
                local instanceId = (type(selectedServer) == "table" and selectedServer.id) or selectedServer
                local ok, err = tryTeleportToServer(placeId, instanceId)
                if ok then
                    showNotification("Teleporting to another server")
                    return true
                end

                lastError = err or lastError or "Teleport failed"
                success = false
            end
        end

        if attempt >= 6 then
            showNotification("Server hop failed: " .. tostring(lastError or "No available servers found"))
            return false
        end

        showNotification("Hop attempt failed; retrying")
        task.wait(2)
    end
end

-- Auto-hop loop (checks SETTINGS.autoServerHop)
local autoHopVersion = 0

local function enforceSuitableServerIfNeeded()
    if not SETTINGS.antiNonBusyServers then
        return
    end

    local currentPlayers = tonumber(Players.NumPlayers) or 0
    if currentPlayers >= SERVER_HOP_MIN_PLAYERS then
        return
    end

    pcall(function()
        showNotification("Anti-busy server check: hopping to a fuller server")
        serverHopNow(true)
    end)
end

task.spawn(function()
    while true do
        if SETTINGS.antiNonBusyServers then
            pcall(enforceSuitableServerIfNeeded)
        end
        task.wait(3)
    end
end)

task.spawn(function()
    while true do
        if SETTINGS.autoServerHop then
            local version = autoHopVersion
            local delaySeconds = getServerStayDurationSeconds()
            local delayText = formatDurationSeconds(delaySeconds)
            showNotification("Next server hop in " .. delayText)

            local elapsed = 0
            while elapsed < delaySeconds do
                task.wait(1)
                if autoHopVersion ~= version or not SETTINGS.autoServerHop then
                    break
                end
                elapsed = elapsed + 1
            end

            if SETTINGS.autoServerHop and autoHopVersion == version then
                pcall(function() serverHopNow(false) end)
            end
        else
            task.wait(1)
        end

        task.wait(10)
    end
end)

-- Dragging logic (drag window by titleBar)
local dragging = false
local dragStart = Vector2.new()
local startPos = window.Position

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = window.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        local abs = {x = (startPos.X.Offset + delta.X), y = (startPos.Y.Offset + delta.Y)}
        window.Position = UDim2.new(startPos.X.Scale, abs.x, startPos.Y.Scale, abs.y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- Make UI scale-friendly on resize
local function onResize()
    local screenSize = workspace.CurrentCamera.ViewportSize
    if screenSize.X < 700 then
        window.Size = UDim2.new(0.96, 0, 0.9, 0)
    else
        window.Size = UDim2.new(0.36, 0, 0.56, 0)
    end
end
RunService.Heartbeat:Connect(onResize)
onResize()

