-- Server hop core functions
local function pickRandomCandidates(list, maxCount)
    local out = {}
    local n = math.min(#list, maxCount)
    for i=1,n do
        local idx = math.random(1, #list)
        table.insert(out, list[idx])
        table.remove(list, idx)
    end
    return out
end

function serverHopNow(immediate)
    local placeId = HOP_PLACE_ID or game.PlaceId
    local currentJob = tostring(game.JobId)
    while true do
        local ok, result = pcall(function()
            local servers = {}
            local cursor = nil
            repeat
                local url = ("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100"):format(placeId)
                if cursor then url = url.."&cursor="..cursor end
                local res = HttpService:GetAsync(url)
                local decoded = HttpService:JSONDecode(res)
                for _, s in ipairs(decoded.data or {}) do
                    if tostring(s.id) ~= currentJob then
                        table.insert(servers, s)
                    end
                end
                cursor = decoded.nextPageCursor
            until not cursor

            if #servers == 0 then return false end

            local candidates = pickRandomCandidates(servers, math.min(SETTINGS.serverHopRange or 6, 24))
            for _, s in ipairs(candidates) do
                local instanceId = s.id or s.uuid or s.playbackId
                if instanceId then
                    local iid = tostring(instanceId)
                    -- try teleport with player argument first, then fallback to without
                    local ok2, err = pcall(function()
                        TeleportService:TeleportToPlaceInstance(placeId, iid, LocalPlayer)
                    end)
                    if not ok2 then
                        warn("Teleport attempt failed (with player):", err)
                        local ok3, err2 = pcall(function()
                            TeleportService:TeleportToPlaceInstance(placeId, iid)
                        end)
                        if ok3 then return true end
                        warn("Teleport attempt failed (no player):", err2)
                    else
                        return true
                    end
                end
            end
            return false
        end)

        if ok and result then
            return
        else
            warn("serverHop iteration failed, retrying...", ok, result)
        end
        task.wait(0.1)
    end
end

-- Auto-hop loop (checks SETTINGS.autoServerHop)
task.spawn(function()
    while true do
        if SETTINGS.autoServerHop then
            local mins = math.max(0.1, (SETTINGS.serverStayMinutes or 5))
            task.wait(mins * 60)
            pcall(function() serverHopNow(false) end)
        else
            task.wait(1)
        end
    end
end)

-- Dragging logic (drag window by titleBar)
local dragging = false
local dragStart = Vector2.new()
local startPos = window.Position

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = window.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        local abs = {x = (startPos.X.Offset + delta.X), y = (startPos.Y.Offset + delta.Y)}
        window.Position = UDim2.new(startPos.X.Scale, abs.x, startPos.Y.Scale, abs.y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

