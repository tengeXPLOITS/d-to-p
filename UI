-- Claiming logic per user's spec
local function findAvailableBooth()
    local stands = workspace:FindFirstChild("Stands")
    if not stands then return nil end
    for _, model in ipairs(stands:GetChildren()) do
        if model:IsA("Model") and model.Name == "Basic Booth" then
            local usernameVal = model:FindFirstChild("Username")
            if usernameVal and (usernameVal.Value == nil or usernameVal.Value == "") then
                return model
            end
        end
    end
    return nil
end

local function teleportToBoothAndClaim(model)
    if not model then return false end
    -- Find ClaimedPart
    local claimedPart = model:FindFirstChild("ClaimedPart") or model:FindFirstChildWhichIsA("BasePart")
    if not claimedPart then return false end
    -- Move player close to claimedPart
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    -- position player a few studs in front of the claimed part and face away from the booth
    local front = claimedPart.CFrame.LookVector
    local distance = 3
    local pos = claimedPart.Position + (front) * distance
    pos = Vector3.new(pos.X, claimedPart.Position.Y + 3, pos.Z)
    pcall(function()
        -- orient to look opposite of the booth front (face away)
        hrp.CFrame = CFrame.new(pos, pos - front)
    end)
    task.wait(0.2)

    -- try to find ProximityPrompt
    local prompt = nil
    for _, att in ipairs(claimedPart:GetDescendants()) do
        if att:IsA("Attachment") then
            local p = att:FindFirstChild("ClaimPrompt") or att:FindFirstChildWhichIsA("ProximityPrompt")
            if p and p:IsA("ProximityPrompt") then
                prompt = p
                break
            end
        end
    end
    if not prompt then
        prompt = model:FindFirstChild("ClaimPrompt", true)
        if prompt and not prompt:IsA("ProximityPrompt") then prompt = nil end
    end

    if not prompt then return false end

    -- Attempt to trigger the prompt; prefer safe client methods
    local success = false
    pcall(function()
        if typeof(fireproximityprompt) == "function" then
            fireproximityprompt(prompt, 1)
            success = true
            return
        end
    end)

    if not success then
        pcall(function()
            if prompt.InputHoldBegin and prompt.InputHoldEnd then
                prompt:InputHoldBegin()
                task.wait(1)
                prompt:InputHoldEnd()
                success = true
                return
            end
        end)
    end

    if not success then
        pcall(function()
            if prompt.Trigger then
                prompt:Trigger()
                success = true
            end
        end)
    end

    return success
end

local function claimFirstAvailable()
    local b = findAvailableBooth()
    if not b then
        warn("No available Basic Booth found")
        return false
    end
    local ok = teleportToBoothAndClaim(b)
    if ok then
        warn("Claim attempt finished")
    else
        warn("Claim attempt failed")
    end
    return ok
end

