local SETTINGS_FILE = "donatetoplayers_settings.json"
local function saveSettings()
    local ok, encoded = pcall(function() return HttpService:JSONEncode(SETTINGS) end)
    if not ok then return end
    if writefile then
        pcall(writefile, SETTINGS_FILE, encoded)
    end
end

local function loadSettings()
    if isfile and isfile(SETTINGS_FILE) then
        local ok, content = pcall(readfile, SETTINGS_FILE)
        if ok and content then
            local suc, obj = pcall(function() return HttpService:JSONDecode(content) end)
            if suc and type(obj) == "table" then
                for k,v in pairs(obj) do SETTINGS[k] = v end
            end
        end
    end
end

