-- Simple control factory
local function addLabel(parent, text)
    return new(parent, "TextLabel", {Text=text, BackgroundTransparency=1, TextColor3=Color3.new(1,1,1), Font=Enum.Font.Gotham, TextSize=14, Size=UDim2.new(0.9,0,0,20)})
