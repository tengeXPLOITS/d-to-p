local function refreshServerMonitor()
    task.spawn(function()
        local placeId = tostring(HOP_PLACE_ID or game.PlaceId)
        local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&limit=100"
        local ok, res = pcall(function()
            if httprequest then
                local r = httprequest({Url = url, Method = "GET"})
                return r and r.Body
            else
                return HttpService:GetAsync(url)
            end
        end)

        if ok and res then
            local body = nil
            pcall(function() body = HttpService:JSONDecode(res) end)
            if body and body.data then
                local available = 0
                for _, v in ipairs(body.data) do
                    if type(v) == "table" and v.id then
                        local playing = tonumber(v.playing)
                        local maxP = tonumber(v.maxPlayers)
                        if playing and maxP and playing < maxP then
                            available = available + 1
                        end
                    end
                end
                updateServerMonitor(available)
            else
                updateServerMonitor(0)
            end
        else
            updateServerMonitor(0)
        end
    end)
end

local function claimFirstAvailable()
    local deadline = os.clock() + 18
    local claimed = false

    while os.clock() < deadline do
        local b = findAvailableBooth()
        if b then
            local ok = teleportToBoothAndClaim(b)
            if ok then
                warn("Claim attempt finished")
                task.spawn(function()
                    task.wait(0.5)
                    sendDanceCommand()
                end)
                pcall(function() sendWebhook("Booth claim result: claimed") end)
                claimed = true
                break
            end
        end

        task.wait(0.8)
    end

    if not claimed then
        warn("Claim attempt failed")
        pcall(function() sendWebhook("Booth claim result: not claimed") end)
    end

    return claimed
end

local function beginAutoClaim()
    if claimLoopActive then
        return
    end

    claimLoopActive = true
    task.spawn(function()
        local ok, err = pcall(claimFirstAvailable)
        if not ok then
            warn("Claim loop error: " .. tostring(err))
        end
        claimLoopActive = false
    end)
end

