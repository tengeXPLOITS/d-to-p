    local toggled = initial
    box.MouseButton1Click:Connect(function()
        toggled = not toggled
        box.Text = toggled and "✓" or ""
        pcall(callback, toggled)
    end)
    local obj = {}
    function obj:Set(b)
        toggled = b and true or false
        box.Text = toggled and "✓" or ""
        pcall(callback, toggled)
    end
    return obj, container
end

-- radio group for choosing one of several options
local function addRadioGroup(parent, options, initial, callback)
    local container = new(parent, "Frame", {Size = UDim2.new(0.9,0,0,40), BackgroundTransparency = 1})
    local layout = new(container, "UIListLayout", {})
    layout.FillDirection = Enum.FillDirection.Horizontal
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0,8)
    local buttons = {}
    local selected = initial
    for i, opt in ipairs(options) do
        local btn = new(container, "TextButton", {Text = opt, Size = UDim2.new(0, 80, 0, 32), BackgroundColor3 = Color3.fromRGB(60,60,60), TextColor3 = Color3.new(1,1,1), Font = Enum.Font.Gotham, TextSize = 14})
        btn.AutoButtonColor = true
        buttons[opt] = btn
        btn.MouseButton1Click:Connect(function()
            selected = opt
            for k, b in pairs(buttons) do
                b.BackgroundColor3 = (k == selected) and Color3.fromRGB(34,139,34) or Color3.fromRGB(60,60,60)
            end
            pcall(callback, selected)
        end)
    end
    -- initialize visuals
    for k, b in pairs(buttons) do
        b.BackgroundColor3 = (k == initial) and Color3.fromRGB(34,139,34) or Color3.fromRGB(60,60,60)
    end
    return function() return selected end, container
end

