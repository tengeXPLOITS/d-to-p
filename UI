-- Simple control factory
local function addLabel(parent, text)
    return new(parent, "TextLabel", {Text=text, BackgroundTransparency=1, TextColor3=Color3.new(1,1,1), Font=Enum.Font.Gotham, TextSize=14, Size=UDim2.new(1,0,0,20)})
end

local function addButton(parent, text, cb)
    local btn = new(parent, "TextButton", {Text = text, Size = UDim2.new(1,0,0,30), BackgroundColor3=Color3.fromRGB(34,139,34), TextColor3=Color3.new(1,1,1), Font=Enum.Font.Gotham, TextSize=14})
    btn.AutoButtonColor = true
    btn.MouseButton1Click:Connect(function() pcall(cb) end)
    return btn
end

local function addTextBox(parent, placeholder, onEnter)
    local box = new(parent, "TextBox", {Text = "", PlaceholderText = placeholder, Size = UDim2.new(1,0,0,28), BackgroundColor3=Color3.fromRGB(44,44,44), TextColor3=Color3.fromRGB(220,220,220), Font=Enum.Font.Gotham, TextSize=14})
    box.FocusLost:Connect(function(enter)
        if enter then pcall(function() onEnter(box.Text) end) end
    end)
    return box
end

