-- labeled toggle: returns toggle object with Set(bool)
local function addToggle(parent, labelText, initial, callback)
    local container = new(parent, "Frame", {Size = UDim2.new(0.9,0,0,34), BackgroundTransparency = 1})
    local lbl = new(container, "TextLabel", {Text = labelText, BackgroundTransparency = 1, TextColor3 = Color3.new(1,1,1), Font = Enum.Font.Gotham, TextSize = 14, Position = UDim2.new(0,0,0,2), Size = UDim2.new(0.8,0,1,0), TextXAlignment = Enum.TextXAlignment.Left})
    local box = new(container, "TextButton", {Text = initial and "✓" or "", BackgroundColor3 = Color3.fromRGB(34,139,34), TextColor3 = Color3.new(1,1,1), Size = UDim2.new(0,28,0,28), Position = UDim2.new(1,-28,0,3), AutoButtonColor = true, Font = Enum.Font.Gotham, TextSize = 18})
    local toggled = initial
    box.MouseButton1Click:Connect(function()
        toggled = not toggled
        box.Text = toggled and "✓" or ""
        pcall(callback, toggled)
    end)
    local obj = {}
    function obj:Set(b)
        toggled = b and true or false
        box.Text = toggled and "✓" or ""
        pcall(callback, toggled)
    end
    return obj, container
end

