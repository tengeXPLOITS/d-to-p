local function startDonationRaisedWebhookWatcher()
    local raised = ensureRaisedStat()
    local lastRaised = parseNumberValue(raised.Value) or 0

    if donationRaisedWebhookConn then
        return
    end

    donationRaisedWebhookConn = raised:GetPropertyChangedSignal("Value"):Connect(function()
        local currentRaised = parseNumberValue(raised.Value) or 0
        local delta = currentRaised - lastRaised
        if delta > 0 then
            local donorLabel = getNearestDonorLabel()
            local webhookOk, webhookErr = sendWebhookEvent(
                "Donation Received",
                "Raised increased by " .. tostring(delta) .. " from " .. tostring(lastRaised) .. " to " .. tostring(currentRaised),
                {
                    { name = "Donor", value = donorLabel, inline = true },
                    { name = "Delta", value = tostring(delta), inline = true },
                    { name = "Raised", value = tostring(currentRaised), inline = true },
                },
                {
                    color = 0x2ECC71,
                    author = { name = "DonateToPlayers UI" },
                    footer = { text = "leaderstats.Raised webhook trigger" },
                }
            )
            if webhookOk then
                pcall(function()
                    showNotification("Donation webhook sent: +" .. tostring(delta))
                end)
            else
                pcall(function()
                    showNotification("Donation webhook failed: " .. tostring(webhookErr))
                end)
            end
        end
        lastRaised = currentRaised
    end)
end

