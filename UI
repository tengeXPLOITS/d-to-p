local function normalizeWebhookUrl(value)
    if value == nil then return "" end
    local url = tostring(value)
    url = string.gsub(url, "^%s+", "")
    url = string.gsub(url, "%s+$", "")
    return url
end

local function getActiveWebhookUrl()
    if type(GLOBAL_ENV.DonateToPlayers_GetCurrentWebhookUrl) == "function" then
        local value = GLOBAL_ENV.DonateToPlayers_GetCurrentWebhookUrl()
        if value ~= nil then
            return normalizeWebhookUrl(value)
        end
    end
    return normalizeWebhookUrl(SETTINGS and SETTINGS.webhookUrl or "")
end

local function parsePreferredPlayerTarget(rawValue)
    local text = tostring(rawValue or "")
    text = string.gsub(text, "%s+", "")
    if text == "" or text == "0" then
        return { min = 0, max = 0 }
    end

    local lo, hi = string.match(text, "^(%d+)%-(%d+)$")
    if lo and hi then
        lo = tonumber(lo)
        hi = tonumber(hi)
        if lo and hi then
            if lo > hi then
                lo, hi = hi, lo
            end
            return { min = lo, max = hi }
        end
    end

    local num = tonumber(text)
    if num and num >= 0 then
        num = math.floor(num)
        return { min = num, max = num }
    end

    return { min = 0, max = 0 }
end

local function sendWebhookPayload(payload)
    local webhookUrl = getActiveWebhookUrl()
    if webhookUrl == "" then
        return false, "No webhook URL"
    end

    local body = HttpService:JSONEncode(payload)
    local ok, err = pcall(function()
        if syn and syn.request then
            syn.request({
                Url = webhookUrl,
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = body,
            })
        elseif request then
            request({
                Url = webhookUrl,
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = body,
            })
        elseif httprequest then
            httprequest({
                Url = webhookUrl,
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = body,
            })
        elseif type(HttpService.PostAsync) == "function" then
            HttpService:PostAsync(webhookUrl, body, Enum.HttpContentType.ApplicationJson)
        else
            error("No supported webhook request API")
        end
    end)

    if ok then
        return true, "Sent"
    end

    return false, tostring(err or "Unknown webhook error")
end

local function sendWebhookEvent(title, description, fields, options)
    local webhookUrl = getActiveWebhookUrl()
    if webhookUrl == "" then
        return false, "No webhook URL"
    end

    local embed = {
        title = title or "Notification",
        description = description or "",
        color = (options and options.color) or 65344,
        fields = fields or {},
        timestamp = DateTime.now():ToIsoDate(),
    }
    if options and options.author then
        embed.author = options.author
    end
    if options and options.footer then
        embed.footer = options.footer
    end
    if options and options.thumbnail then
        embed.thumbnail = options.thumbnail
    end

    return sendWebhookPayload({ embeds = { embed } })
end

