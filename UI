local function queueLoadOnTeleport()
    if GLOBAL_ENV.DonateToPlayers_QueuedTeleport then
        return
    end

    local settingsJson = "{}"
    pcall(function()
        settingsJson = HttpService:JSONEncode(SETTINGS or {})
    end)

