local function parseServerStayDuration(rawValue)
    if rawValue == nil then
        return nil
    end

    if type(rawValue) == "number" then
        return math.max(1, math.floor(rawValue * 60))
    end

    local text = tostring(rawValue)
    text = string.gsub(text, "%s+", "")
    if text == "" then
        return nil
    end

    local unit = string.sub(text, -1)
    local valueText = text
    if unit == "s" or unit == "m" or unit == "h" then
        valueText = string.sub(text, 1, -2)
    end

    local value = tonumber(valueText)
    if not value then
        return nil
    end

    if unit == "s" then
        return math.max(1, math.floor(value))
    elseif unit == "m" then
        return math.max(1, math.floor(value * 60))
    elseif unit == "h" then
        return math.max(1, math.floor(value * 3600))
    end

    return math.max(1, math.floor(value * 60))
end

local function getServerStayDurationSeconds()
    local parsed = parseServerStayDuration(SETTINGS.serverStayDuration or SETTINGS.serverStayMinutes)
    if parsed then
        return parsed
    end
    return 300
end

local function formatDurationSeconds(seconds)
    local total = math.max(1, math.floor(tonumber(seconds) or 0))
    if total >= 60 then
        local mins = math.floor(total / 60)
        local secs = total % 60
        if secs == 0 then
            return tostring(mins) .. "m"
        end
        return tostring(mins) .. "m " .. tostring(secs) .. "s"
    end
    return tostring(total) .. "s"
end

