local function getOwnedBoothModel()
    local stands = workspace:FindFirstChild("Stands")
    if not stands then
        return nil
    end

    for _, model in ipairs(stands:GetChildren()) do
        if model:IsA("Model") and model.Name == "Basic Booth" then
            local usernameVal = model:FindFirstChild("Username") or model:FindFirstChild("username")
            if usernameVal and usernameVal:IsA("StringValue") then
                local ownerName = tostring(usernameVal.Value or "")
                if string.lower(ownerName) == string.lower(LocalPlayer.Name) then
                    return model
                end
            end
        end
    end

    return nil
end

local function getBoothPatrolTargets(model)
    local anchorPart = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
    if not anchorPart then
        return {}
    end

    local boothCFrame, boothSize = model:GetBoundingBox()
    local front = boothCFrame.LookVector
    local right = boothCFrame.RightVector
    local base = anchorPart.Position
    local depth = math.max(boothSize.Z, 10)
    local width = math.max(boothSize.X, 8)

    return {
        base + front * (depth / 2 + 6),
        base + front * (depth / 2 + 8) + right * (width / 2 + 3),
        base + front * (depth / 2 + 8) + right * -(width / 2 + 3),
        base + front * (depth / 2 + 5),
    }
end

local function getBoothReturnTarget(model)
    local anchorPart = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
    if not anchorPart then
        return nil
    end

    local boothCFrame, boothSize = model:GetBoundingBox()
    local front = boothCFrame.LookVector
    local base = anchorPart.Position
    local depth = math.max(boothSize.Z, 10)
    return base - front * (depth / 2 + 6)
end

local PLAZA_AREA_MIN = Vector3.new(-25.709, 6.297, -40.785)
local PLAZA_AREA_MAX = Vector3.new(82.860, 6.751, 66.287)

local function clampTargetToPlazaArea(targetPos)
    if typeof(targetPos) ~= "Vector3" then
        return targetPos
    end

    return Vector3.new(
        math.clamp(targetPos.X, PLAZA_AREA_MIN.X, PLAZA_AREA_MAX.X),
        math.clamp(targetPos.Y, PLAZA_AREA_MIN.Y, PLAZA_AREA_MAX.Y),
        math.clamp(targetPos.Z, PLAZA_AREA_MIN.Z, PLAZA_AREA_MAX.Z)
    )
end

local function moveCharacterToWaypoint(targetPos, speedOverride)
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    if not hrp or not humanoid then
        return false
    end

    targetPos = clampTargetToPlazaArea(targetPos)
    local targetSpeed = tonumber(speedOverride) or 21
    humanoid.WalkSpeed = targetSpeed
    humanoid:MoveTo(targetPos)
    task.wait(0.35)
    return true
end

local function faceBooth(model)
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp or not model then
        return
    end

    local boothCFrame = model:GetBoundingBox()
    local boothLook = boothCFrame.LookVector
    local lookVector = Vector3.new(boothLook.X, 0, boothLook.Z)
    if lookVector.Magnitude <= 0 then
        lookVector = Vector3.new(0, 0, -1)
    end

    hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + lookVector.Unit)
end

local function faceAwayFromBooth(model)
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp or not model then
        return
    end

    local boothCFrame = model:GetBoundingBox()
    local boothLook = boothCFrame.LookVector
    local lookVector = Vector3.new(-boothLook.X, 0, -boothLook.Z)
    if lookVector.Magnitude <= 0 then
        lookVector = Vector3.new(0, 0, 1)
    end

    hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + lookVector.Unit)
end

local function quickLookAtPlayer(player)
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    if not hrp or not humanoid then
        return
    end

    local playerChar = player and player.Character
    local playerHRP = playerChar and playerChar:FindFirstChild("HumanoidRootPart")
    if not playerHRP then
        return
    end

    local targetLook = playerHRP.Position + Vector3.new(0, 1.2, 0)
    local startPos = hrp.Position
    hrp.CFrame = CFrame.lookAt(startPos, targetLook)
end

