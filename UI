local function playSelectedEmote()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then
        return nil
    end
    local emote = getSelectedEmoteData()
    if not emote or not emote.id then
        return nil
    end
    local animator = humanoid:FindFirstChildOfClass("Animator")
    if not animator then
        animator = Instance.new("Animator")
        animator.Parent = humanoid
    end
    if danceTrack then
        pcall(function()
            danceTrack:Stop()
        end)
        danceTrack = nil
    end
    local animation = Instance.new("Animation")
    animation.AnimationId = "rbxassetid://" .. tostring(emote.id)
    local ok, track = pcall(function()
        return animator:LoadAnimation(animation)
    end)
    animation:Destroy()
    if not ok or not track then
        return nil
    end
    track.Priority = Enum.AnimationPriority.Action
    track.Looped = true
    danceTrack = track
    pcall(function()
        track:Play()
    end)
    return track
end

local function startDanceLoop()
    if danceLoopThread then
        return
    end
    SETTINGS.dance = true
    pcall(saveSettings)
    danceLoopThread = task.spawn(function()
        if not playSelectedEmote() then
            SETTINGS.dance = false
            pcall(saveSettings)
            danceLoopThread = nil
            return
        end
        while SETTINGS.dance do
            task.wait(0.5)
        end
        if danceTrack then
            pcall(function() danceTrack:Stop() end)
            danceTrack = nil
        end
        danceLoopThread = nil
    end)
end

