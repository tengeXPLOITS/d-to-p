local function pickRandomCandidates(list, maxCount)
    local out = {}
    local n = math.min(#list, maxCount)
    for i=1,n do
        local idx = math.random(1, #list)
        table.insert(out, list[idx])
        table.remove(list, idx)
    end
    return out
end

local lastServerHopAt = os.clock()

local function updateServerHopTimer()
    if not serverHopTimerLabel then return end
    local mins = math.max(0.1, (SETTINGS.serverStayMinutes or 5))
    if not SETTINGS.autoServerHop then
        serverHopTimerLabel.Text = "Next hop: disabled"
        return
    end
    local elapsed = os.clock() - lastServerHopAt
    local remaining = math.max(0, math.floor(mins * 60 - elapsed))
    local m = math.floor(remaining / 60)
    local s = remaining % 60
    serverHopTimerLabel.Text = string.format("Next hop: %02dm %02ds", m, s)
end

