local function parsePreferredPlayerTarget(rawValue)
    local text = tostring(rawValue or "")
    text = string.gsub(text, "%s+", "")
    if text == "" or text == "0" then
        return { min = 0, max = 0 }
    end

    local lo, hi = string.match(text, "^(%d+)%-(%d+)$")
    if lo and hi then
        lo = tonumber(lo)
        hi = tonumber(hi)
        if lo and hi then
            if lo > hi then
                lo, hi = hi, lo
            end
            return { min = lo, max = hi }
        end
    end

    local num = tonumber(text)
    if num and num >= 0 then
        num = math.floor(num)
        return { min = num, max = num }
    end

    return { min = 0, max = 0 }
end

local function sendWebhookPayload(payload)
    local webhookUrl = getActiveWebhookUrl()
    if webhookUrl == "" then
        return false, "No webhook URL"
    end

    local body = HttpService:JSONEncode(payload)
    local ok, err = pcall(function()
        if syn and syn.request then
            syn.request({
                Url = webhookUrl,
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = body,
            })
        elseif request then
            request({
                Url = webhookUrl,
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = body,
            })
        elseif httprequest then
            httprequest({
                Url = webhookUrl,
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = body,
            })
        elseif type(HttpService.PostAsync) == "function" then
            HttpService:PostAsync(webhookUrl, body, Enum.HttpContentType.ApplicationJson)
        else
            error("No supported webhook request API")
        end
    end)

    if ok then
        return true, "Sent"
    end

    return false, tostring(err or "Unknown webhook error")
end

local function sendWebhookEvent(title, description, fields, options)
    local webhookUrl = getActiveWebhookUrl()
    if webhookUrl == "" then
        return false, "No webhook URL"
    end

    local embed = {
        title = title or "Notification",
        description = description or "",
        color = (options and options.color) or 65344,
        fields = fields or {},
        timestamp = DateTime.now():ToIsoDate(),
    }
    if options and options.author then
        embed.author = options.author
    end
    if options and options.footer then
        embed.footer = options.footer
    end
    if options and options.thumbnail then
        embed.thumbnail = options.thumbnail
    end

    return sendWebhookPayload({ embeds = { embed } })
end

local function requestJsonEndpoint(url, method, body)
    local requestFunc = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
    if not requestFunc then
        return nil
    end

    local payload = nil
    if body ~= nil then
        payload = {
            Url = url,
            Method = tostring(method or "GET"),
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode(body),
        }
    else
        payload = {
            Url = url,
            Method = tostring(method or "GET"),
        }
    end

    local ok, response = pcall(function()
        return requestFunc(payload)
    end)
    if not ok or not response or not response.Body then
        return nil
    end

    local decodeOk, decoded = pcall(function()
        return HttpService:JSONDecode(response.Body)
    end)
    if not decodeOk or not decoded then
        return nil
    end

    return decoded
end

local function resolveGeoLocationLabel(userLat, userLon)
    if type(userLat) ~= "number" or type(userLon) ~= "number" then
        return "Unknown"
    end

    local gridLat = math.floor(userLat)
    local gridLon = math.floor(userLon)
    local geoUrl = "https://www.roblox.com/geolocation/" .. tostring(gridLat) .. ".json"
    local geoData = requestJsonEndpoint(geoUrl, "GET")
    if not geoData then
        return "Unknown"
    end

    local locationInfo = geoData[tostring(gridLon)] or geoData[gridLon]
    if not locationInfo then
        return "Unknown"
    end

    local country = tostring(locationInfo.country or "Unknown")
    local continent = tostring(locationInfo.continent or "Unknown")
    local countryCode = tostring(locationInfo.code or "??")
    if country == "Unknown" and continent ~= "Unknown" then
        return continent
    end
    return country .. " (" .. countryCode .. ")"
end

local function getServerLocationLabel()
    local teleportService = game:GetService("TeleportService")
    if teleportService and type(teleportService.GetServerInfoForGameInstanceAsync) == "function" then
        local ok, info = pcall(function()
            return teleportService:GetServerInfoForGameInstanceAsync(game.JobId)
        end)
        if ok and info then
            if type(info.serverLocation) == "string" and info.serverLocation ~= "" then
                return tostring(info.serverLocation)
            end
            if type(info.region) == "string" and info.region ~= "" then
                return tostring(info.region)
            end
            if type(info.location) == "string" and info.location ~= "" then
                return tostring(info.location)
            end
        end
    end

    local placeId = tonumber(HOP_PLACE_ID or game.PlaceId) or game.PlaceId
    local publicServers = requestJsonEndpoint(
        "https://games.roblox.com/v1/games/" .. tostring(placeId) .. "/servers/Public?limit=10&excludeFullGames=true",
        "GET"
    )
    if not publicServers or type(publicServers.data) ~= "table" then
        return "Unknown"
    end

    local servers = publicServers.data or {}
    for _, server in ipairs(servers) do
        local serverId = server and server.id
        if serverId then
            local joinPayload = {
                placeId = tonumber(placeId),
                gameId = tostring(serverId),
                gameJoinAttemptId = HttpService:GenerateGUID(false),
            }

            local joinInfo = requestJsonEndpoint(
                "https://gamejoin.roblox.com/v2/join-game-instance",
                "POST",
                joinPayload
            )
            if joinInfo and joinInfo.joinScript and joinInfo.joinScript.SessionId then
                local sessionIdStr = tostring(joinInfo.joinScript.SessionId)
                if sessionIdStr and sessionIdStr ~= "" and not string.find(sessionIdStr, "http", 1, true) then
                    local decodeOk, sessionInfo = pcall(function()
                        return HttpService:JSONDecode(sessionIdStr)
                    end)
                    if decodeOk and sessionInfo and type(sessionInfo) == "table" then
                        local lat = tonumber(sessionInfo.Latitude)
                        local lon = tonumber(sessionInfo.Longitude)
                        if lat and lon then
                            return resolveGeoLocationLabel(lat, lon)
                        end
                    end
                end
            end
        end
    end

    return "Unknown"
end

