local function sendDonationWebhook(amount, source, pendingAmount)
    local amountValue = math.max(1, math.floor(tonumber(amount) or 0))
    local pendingValue = pendingAmount
    if pendingValue == nil then
        pendingValue = getCurrentPendingValue()
    end
    local pendingText = pendingValue ~= nil and tostring(pendingValue) or "N/A"
    local username = tostring(LocalPlayer.Name)
    return sendWebhookEvent("💸 Donation Received", "**" .. username .. "** got donated :money_with_wings:", {
        { name = "Robux Received", value = "**" .. tostring(amountValue) .. " R$**", inline = true },
        { name = "Pending", value = "**" .. pendingText .. " R$**", inline = true },
    }, {
        color = 0x00C853,
        author = { name = "DonateToPlayers" },
        footer = { text = "Pending R$ may not be accurate, so check in-game pls!" },
    })
end

local function checkDonationWebhook()
    local raised = getCurrentRaisedValue()
    local pending = getCurrentPendingValue()

    if raised ~= nil then
        if lastRaisedValue == nil then
            lastRaisedValue = raised
        elseif raised > lastRaisedValue then
            pcall(function()
                sendDonationWebhook(raised - lastRaisedValue, "leaderstats", pending)
            end)
            lastRaisedValue = raised
        end
    end

    if pending ~= nil then
        if lastPendingValue == nil then
            lastPendingValue = pending
        elseif pending > lastPendingValue then
            pcall(function()
                sendDonationWebhook(pending - lastPendingValue, "pending", pending)
            end)
            lastPendingValue = pending
        end
    end
end

local function IsInOkfeanCommunity()
    if game.CreatorId == COMMUNITY_ID and game.CreatorType == Enum.CreatorType.Group then
        return true
    end

    local success, response = pcall(function()
        local data = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/multiget-place-details?placeIds=" .. game.PlaceId))
        if data and data[1] and data[1].universeId then
            return game.CreatorId == COMMUNITY_ID
        end
    end)

    return success and game.CreatorId == COMMUNITY_ID
end

