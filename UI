local function parseNumberValue(value)
    if value == nil then return nil end
    local str = tostring(value)
    str = string.gsub(str, "%s", "")
    str = string.gsub(str, "[^%d%.%-]", "")
    return tonumber(str)
end

local function ensureRaisedStat()
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if not leaderstats then
        leaderstats = Instance.new("Folder")
        leaderstats.Name = "leaderstats"
        leaderstats.Parent = LocalPlayer
    end
    local raised = leaderstats:FindFirstChild("Raised")
    if not raised then
        raised = Instance.new("IntValue")
        raised.Name = "Raised"
        raised.Parent = leaderstats
    end
    return raised
end

local function findRaisedStat()
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if not leaderstats then
        return ensureRaisedStat()
    end

    local function isRaiseStat(obj)
        local rawName = tostring(obj and obj.Name or "")
        local normalizedName = string.gsub(string.lower(rawName), "[^a-z]", "")
        return obj and (obj:IsA("IntValue") or obj:IsA("NumberValue") or obj:IsA("StringValue")) and (
            string.find(normalizedName, "ra", 1, true)
            or string.find(normalizedName, "ro", 1, true)
            or string.find(normalizedName, "don", 1, true)
        )
    end

    for _, child in ipairs(leaderstats:GetChildren()) do
        if isRaiseStat(child) then
            return child
        end
    end

    local found = nil
    local function crawl(root)
        for _, child in ipairs(root:GetChildren()) do
            if isRaiseStat(child) then
                found = child
                return true
            end
            if crawl(child) then
                return true
            end
        end
        return false
    end
    crawl(LocalPlayer)
    return found or ensureRaisedStat()
end

local function getCurrentRaisedValue()
    local stat = findRaisedStat()
    if not stat then return nil end
    return parseNumberValue(stat.Value)
end

local function simulateDonation(amount)
    local raised = ensureRaisedStat()
    local current = parseNumberValue(raised.Value) or 0
    local addAmount = math.max(1, math.floor(tonumber(amount) or 0))
    raised.Value = current + addAmount
    return raised.Value
end

