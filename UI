-- Server hop core functions
local function pickRandomCandidates(list, maxCount)
    local out = {}
    local n = math.min(#list, maxCount)
    for i=1,n do
        local idx = math.random(1, #list)
        table.insert(out, list[idx])
        table.remove(list, idx)
    end
    return out
end

function serverHopNow(immediate)
    local placeId = tostring(HOP_PLACE_ID or game.PlaceId)
    local servers = {}
    if not httprequest then
        warn("No executor http request available; server hop may fail")
        return
    end
    -- Fetch server list using executor httprequest (like old.lua)
    local ok, res = pcall(function()
        return httprequest({Url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&limit=100", Method = "GET"})
    end)
    if ok and res and res.Body then
        local body = nil
        pcall(function() body = HttpService:JSONDecode(res.Body) end)
        if body and body.data then
            for _, v in ipairs(body.data) do
                if type(v) == "table" and v.id then
                    table.insert(servers, 1, v.id)
                end
            end
        end
    else
        warn("Failed to fetch server list via executor HTTP")
    end

    -- Spawn loop to attempt teleports repeatedly (matches old.lua behavior)
    task.spawn(function()
        while task.wait(0.5) do
            if #servers > 0 then
                pcall(function()
                    TeleportService:TeleportToPlaceInstance(tonumber(placeId) or placeId, servers[math.random(1, #servers)], LocalPlayer)
                end)
            end
        end
    end)

    -- Retry on teleport init failed
    TeleportService.TeleportInitFailed:Connect(function()
        if #servers > 0 then
            pcall(function()
                TeleportService:TeleportToPlaceInstance(tonumber(placeId) or placeId, servers[math.random(1, #servers)], LocalPlayer)
            end)
        end
    end)
end

-- Auto-hop loop (checks SETTINGS.autoServerHop)
task.spawn(function()
    while true do
        if SETTINGS.autoServerHop then
            local mins = math.max(0.1, (SETTINGS.serverStayMinutes or 5))
            task.wait(mins * 60)
            pcall(function() serverHopNow(false) end)
        else
            task.wait(1)
        end
    end
end)

-- Dragging logic (drag window by titleBar)
local dragging = false
local dragStart = Vector2.new()
local startPos = window.Position

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = window.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        local abs = {x = (startPos.X.Offset + delta.X), y = (startPos.Y.Offset + delta.Y)}
        window.Position = UDim2.new(startPos.X.Scale, abs.x, startPos.Y.Scale, abs.y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

