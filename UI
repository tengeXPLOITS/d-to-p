-- Claiming logic per user's spec
local function findAvailableBooth()
    local stands = workspace:FindFirstChild("Stands")
    if not stands then return nil end
    for _, model in ipairs(stands:GetChildren()) do
        if model:IsA("Model") and model.Name == "Basic Booth" then
            local usernameVal = model:FindFirstChild("Username") or model:FindFirstChild("username")
            if usernameVal and usernameVal:IsA("StringValue") and (usernameVal.Value == nil or usernameVal.Value == "") then
                return model
            end
        end
    end
    return nil
end

local function secureBoothOwnership(model)
    if not model then
        return false, "missing booth"
    end

    local usernameVal = model:FindFirstChild("Username") or model:FindFirstChild("username")
    if not usernameVal or not usernameVal:IsA("StringValue") then
        showNotification("Booth ownership check failed: missing Username StringValue")
        return false, "missing username value"
    end

    local expectedName = tostring(LocalPlayer.Name)
    local existingName = tostring(usernameVal.Value or "")
    if existingName == "" then
        usernameVal.Value = expectedName
        existingName = expectedName
    end

    local matches = string.lower(existingName) == string.lower(expectedName)
    local statusText = matches and ("Booth ownership confirmed: " .. existingName) or ("Booth ownership mismatch: expected " .. expectedName .. ", found " .. existingName)
    showNotification(statusText)
    return matches, existingName
end

local function teleportToBoothAndClaim(model)
    if not model then return false end

    local claimedPart = model:FindFirstChild("ClaimedPart") or model:FindFirstChildWhichIsA("BasePart")
    if not claimedPart then return false end

    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end

    local anchorPart = claimedPart or model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
    if not anchorPart then return false end

    local function getFacingDirection(cframe, towardPosition)
        local front = cframe.LookVector
        if towardPosition and (towardPosition - cframe.Position).Magnitude > 0 then
            local toward = (towardPosition - cframe.Position).Unit
            if front:Dot(toward) > 0 then
                return -front
            end
        end
        return front
    end

    local function setPlayerPosition(pos, lookAt)
        pcall(function()
            local human = char:FindFirstChildOfClass("Humanoid")
            if human then
                human.Sit = false
            end
            if hrp and hrp.CFrame then
                if lookAt then
                    hrp.CFrame = CFrame.new(pos, lookAt)
                else
                    hrp.CFrame = CFrame.new(pos)
                end
            end
        end)
    end

    local initialPos = Vector3.new(anchorPart.Position.X, anchorPart.Position.Y + 2, anchorPart.Position.Z)
    local initialLook = (hrp.CFrame and hrp.CFrame.LookVector) or Vector3.new(0, 0, -1)
    setPlayerPosition(initialPos, initialPos + initialLook)
    task.wait(0.12)

    -- Give the booth and prompt a short moment to settle before claiming from range
    task.wait(1.25)

    local function getClaimPromptCandidates()
        local prompts = {}
        local seen = {}
        local function add(promptObj)
            if promptObj and promptObj:IsA("ProximityPrompt") and not seen[promptObj] then
                prompts[#prompts + 1] = promptObj
                seen[promptObj] = true
            end
        end

        for _, att in ipairs(claimedPart:GetDescendants()) do
            if att:IsA("Attachment") then
                local p = att:FindFirstChild("ClaimPrompt") or att:FindFirstChildWhichIsA("ProximityPrompt")
                if p then
                    add(p)
                end
            end
        end

        for _, inst in ipairs(model:GetDescendants()) do
            if inst:IsA("ProximityPrompt") then
                add(inst)
            end
        end

        if #prompts == 0 then
            for _, inst in ipairs(workspace:GetDescendants()) do
                if inst:IsA("ProximityPrompt") then
                    local action = string.lower(inst.ActionText or "")
                    local object = string.lower(inst.ObjectText or "")
                    if action == "claim" or object == "claim" or string.find(action, "claim", 1, true) or string.find(object, "claim", 1, true) then
                        local parentPart = inst.Parent and inst.Parent:IsA("BasePart") and inst.Parent or nil
                        if parentPart then
                            local dist = (parentPart.Position - anchorPart.Position).Magnitude
                            if dist < 80 then
                                add(inst)
                            end
                        end
                    end
                end
            end
        end

        return prompts
    end

    local promptCandidates = getClaimPromptCandidates()
    local prompt = nil
    for _, candidate in ipairs(promptCandidates) do
        if candidate and candidate.Enabled ~= false then
            prompt = candidate
            break
        end
    end

    local dist = 7
    local approachCFrame = anchorPart.CFrame
    local approachOrigin = anchorPart.Position
    local promptPosition = nil
    local promptCFrame = nil
    if prompt and prompt.Parent then
        if prompt.Parent:IsA("Attachment") then
            promptCFrame = prompt.Parent.WorldCFrame
            promptPosition = prompt.Parent.WorldPosition
            approachCFrame = promptCFrame
            approachOrigin = promptPosition
        elseif prompt.Parent:IsA("BasePart") then
            promptCFrame = prompt.Parent.CFrame
            promptPosition = prompt.Parent.Position
            approachCFrame = promptCFrame
            approachOrigin = promptPosition
        end
    end
    local approachFront = getFacingDirection(approachCFrame, anchorPart.Position)
    local finalPos = approachOrigin + approachFront * dist
    finalPos = Vector3.new(finalPos.X, anchorPart.Position.Y + 2, finalPos.Z)

    local boothCFrame, boothSize = model:GetBoundingBox()
    local boothOrigin = boothCFrame.Position
    local function getBoothFrontDirection()
        local dir = Vector3.new(boothCFrame.LookVector.X, 0, boothCFrame.LookVector.Z)
        if dir.Magnitude > 0.1 then
            return dir.Unit
        end
        local anchorDir = Vector3.new(anchorPart.CFrame.LookVector.X, 0, anchorPart.CFrame.LookVector.Z)
        if anchorDir.Magnitude > 0.1 then
            return anchorDir.Unit
        end
        return Vector3.new(0, 0, -1)
    end
    local boothFront = getBoothFrontDirection()
    local boothHalfDepth = math.abs(boothFront:Dot(boothCFrame.RightVector)) * boothSize.X/2 + math.abs(boothFront:Dot(boothCFrame.LookVector)) * boothSize.Z/2
    local boothDistance = boothHalfDepth + 2.8
    local function getAfterClaimPosition()
        local yPos = anchorPart.Position.Y + 2
        local distanceFromBooth = math.max(boothHalfDepth + 2.8, 3.0)
        local finalPos = boothOrigin + boothFront * distanceFromBooth
        return Vector3.new(finalPos.X, yPos, finalPos.Z)
    end

    local function robustFirePrompt(promptObj)
        if not promptObj then
            return false
        end

        if promptObj.Enabled == false then
            pcall(function()
                promptObj.Enabled = true
            end)
        end

        local promptPosition = anchorPart.Position
        local promptCFrame = anchorPart.CFrame
        pcall(function()
            if promptObj.Parent and promptObj.Parent:IsA("Attachment") then
                promptPosition = promptObj.Parent.WorldPosition
                promptCFrame = promptObj.Parent.WorldCFrame
            elseif promptObj.Parent and promptObj.Parent:IsA("BasePart") then
                promptPosition = promptObj.Parent.Position
                promptCFrame = promptObj.Parent.CFrame
            end
        end)

        local frontDir = promptCFrame.LookVector
        local attempts = {
            {offset = frontDir * 6.5},
            {offset = frontDir * 7.5},
            {offset = frontDir * 6.5 + Vector3.new(0, 0.35, 0)},
            {offset = frontDir * 5},
        }

        for _, attempt in ipairs(attempts) do
            local tryPos = Vector3.new(promptPosition.X + attempt.offset.X, promptPosition.Y + 2 + attempt.offset.Y, promptPosition.Z + attempt.offset.Z)
            local lookAt = promptPosition + Vector3.new(0, 1.2, 0)
            setPlayerPosition(tryPos, lookAt)
            task.wait(0.06)

            local fired = false

            pcall(function()
                if typeof(fireproximityprompt) == "function" then
                    fireproximityprompt(promptObj, 1)
                    fired = true
                end
            end)
            if fired then return true end

            pcall(function()
                if promptObj.InputHoldBegin and promptObj.InputHoldEnd and promptObj.Enabled ~= false then
                    promptObj:InputHoldBegin()
                    task.wait(math.max(0.25, math.min(0.8, (promptObj.HoldDuration or 1) - 0.2)))
                    promptObj:InputHoldEnd()
                    fired = true
                end
            end)
            if fired then return true end

            pcall(function()
                if promptObj.Trigger and promptObj.Enabled ~= false then
                    promptObj:Trigger()
                    fired = true
                end
            end)
            if fired then return true end

            pcall(function()
                local part = promptObj.Parent and promptObj.Parent:IsA("BasePart") and promptObj.Parent or nil
                if part and firetouchinterest then
                    pcall(function()
                        firetouchinterest(part, hrp, 0)
                        task.wait(0.05)
                        firetouchinterest(part, hrp, 1)
                    end)
                    pcall(function()
                        firetouchinterest(hrp, part, 0)
                        task.wait(0.05)
                        firetouchinterest(hrp, part, 1)
                    end)
                    fired = true
                end
            end)
            if fired then return true end
        end

        return false
    end

    local okFire = false
    if prompt then
        okFire = robustFirePrompt(prompt)
    end

    if okFire then
        task.wait(0.08)
        local frontDir = getFacingDirection(promptCFrame or anchorPart.CFrame, anchorPart.Position)
        setPlayerPosition(finalPos, finalPos + frontDir)
        task.wait(5.5)
        local afterPos = getAfterClaimPosition()
        setPlayerPosition(afterPos, afterPos + boothFront)
        task.wait(0.35)
        setPlayerPosition(afterPos, afterPos + boothFront)
        local ownerOk = secureBoothOwnership(model)
        return ownerOk
    end

    task.wait(0.08)
    local fallbackDir = getFacingDirection(promptCFrame or anchorPart.CFrame, anchorPart.Position)
    setPlayerPosition(finalPos, finalPos + fallbackDir)
    task.wait(0.12)

    if prompt then
        okFire = robustFirePrompt(prompt)
    end

    if okFire then
        task.wait(5.5)
        local afterPos = getAfterClaimPosition()
        setPlayerPosition(afterPos, afterPos + boothFront)
        task.wait(0.35)
        setPlayerPosition(afterPos, afterPos + boothFront)
        local ownerOk = secureBoothOwnership(model)
        return ownerOk
    end

    return false
end

local function claimFirstAvailable()
    for attempt = 1, 5 do
        local b = findAvailableBooth()
        if not b then
            warn("No available Basic Booth found")
            return false
        end

        local ok, ownerName = teleportToBoothAndClaim(b)
        if ok == true then
            warn("Claim attempt finished")
            return true
        end

        showNotification("Booth ownership mismatch, trying another booth")
    end

    warn("Claim attempt failed")
    return false
end

